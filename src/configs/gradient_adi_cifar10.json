{
    "epochs": 50,
    "lr": 0.001,
    "save_model": true,
    "enable_cifar10_optimization": true,
    "k": 2,
    "batch_size": 128,
    "communication":{
        "communication_protocol": "FedSGD",
        "iteration_per_aggregation": 1
    },
    "dataset":{
        "dataset_name": "cifar10",
        "num_classes": 10
    },
    "model_list":{
        "0": {
            "type": "resnet18",
            "input_dim": 512,
            "output_dim": 10,
            "path": "random_20"
        },
        "1": {
            "type": "resnet18",
            "input_dim": 512,
            "output_dim": 10,
            "path": "random_20"
        },
        "apply_trainable_layer": 1,
        "global_model": "ClassificationModelHostTrainableHead"
    },
    "attack_list": {
        "0": {
            "name": "GradientBasedADI",
            "parameters": {
                "party": [0],
                "attacker_party_id": 0,
                "victim_party_id": 1,
                "attack_sample_num": 10,
                "victim_sample_size": 20,
                "max_rounds": 10,
                "delta_lr": 0.01,
                "delta_optim_steps": 1,
                "target_label": 0,
                "domination_threshold": 0.5,
                "alpha": 1.0,
                "beta": 1.0,
                "gamma": 0.1,
                "sigma": 0.9,
                "mutation_mode": "random_mutation",
                "bound_scale": 1.0,
                "random_mutation_std": 0.001
            }
        }
    }
}
