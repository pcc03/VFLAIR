{
    "epochs": 50,
    "lr": 0.001,
    "save_model": true,
    "enable_cifar10_optimization": true,
    "k": 2,
    "batch_size": 128,
    "communication":{
        "communication_protocol": "FedSGD",
        "iteration_per_aggregation": 1
    },
    "dataset":{
        "dataset_name": "cifar10",
        "num_classes": 10
    },
    "model_list":{
        "0": {
            "type": "resnet18",
            "input_dim": 512,
            "output_dim": 10,
            "path": "random_20"
        },
        "1": {
            "type": "resnet18",
            "input_dim": 512,
            "output_dim": 10,
            "path": "random_20"
        },
        "apply_trainable_layer": 1,
        "global_model": "ClassificationModelHostTrainableHead"
    },
    "attack_list": {
        "0": {
            "name": "PGD",
            "parameters": {
                "party": [1],
                "eps": 0.03,
                "alpha": 0.0078,
                "steps": 20,
                "random_start": 1,
                "clamp_min": 0.0,
                "clamp_max": 1.0,
                "attack_on": "test"
            }
        }
    }
}
