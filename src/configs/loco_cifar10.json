{
    "epochs": 50,
    "lr": 0.001,
    "save_model": true,
    "enable_cifar10_optimization": true,
    "k": 2,
    "batch_size": 128,
    "communication": {
        "communication_protocol": "FedSGD",
        "iteration_per_aggregation": 1
    },
    "dataset": {
        "dataset_name": "cifar10",
        "num_classes": 10
    },
    "model_list": {
        "0": {
            "type": "resnet18",
            "input_dim": 512,
            "output_dim": 10,
            "path": "random_20"
        },
        "1": {
            "type": "resnet18",
            "input_dim": 512,
            "output_dim": 10,
            "path": "random_20"
        },
        "apply_trainable_layer": 1,
        "global_model": "ClassificationModelHostTrainableHead"
    },
    "attack_list": {
        "0": {
            "name": "LOCO",
            "parameters": {
                "party": [0, 1],
                "attack_on": "test",
                "replacement": "zero"
            }
        }
    }
}
