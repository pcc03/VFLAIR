{
  "epochs": 50,
  "lr": 0.01,
  "save_model": true,
  "enable_cifar10_optimization": true,
  "k": 2,
  "batch_size": 128,
  "communication": {
    "communication_protocol": "FedSGD",
    "iteration_per_aggregation": 1
  },
  "dataset": {
    "dataset_name": "cifar10",
    "num_classes": 10
  },
  "model_list": {
    "0": {
      "type": "vgg16_vfl",
      "input_dim": 512,
      "output_dim": 10752,
      "embedding_dim": 10752,
      "return_embedding": true,
      "path": "random_vgg16"
    },
    "1": {
      "type": "vgg16_vfl",
      "input_dim": 512,
      "output_dim": 10752,
      "embedding_dim": 10752,
      "return_embedding": true,
      "path": "random_vgg16"
    },
    "apply_trainable_layer": 1,
    "global_model": "ClassificationModelHostTrainableHead"
  }
}
